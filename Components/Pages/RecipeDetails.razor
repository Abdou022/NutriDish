@page "/recipes/{Id:int}"
@using NutriDish.Models
@using NutriDish.Services
@inject IRecipeService RecipeService
@inject NavigationManager Nav
@rendermode InteractiveServer


@if (recipe == null)
{
    <div class="recipe-loading">
        <div class="loading-spinner"></div>
        <p>Préparation en cours...</p>
    </div>
}
else
{
    <!-- Hero Section -->
    <div class="recipe-hero" style="background-image: url('@(string.IsNullOrEmpty(recipe.ImageUrl) ? "" : recipe.ImageUrl)')">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <button class="back-btn" @onclick="GoBack">
                ← Retour aux recettes
            </button>
            <div class="hero-meta">
                <span class="meta-tag">@recipe.Category?.Name</span>
                <span class="meta-tag">@recipe.CuisineType?.Name</span>
            </div>
            <h1 class="recipe-title">@recipe.Name</h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="recipe-body">

        <!-- Left Column -->
        <div class="recipe-main">

            <!-- Persons Selector -->
            <div class="persons-card">
                <span class="persons-label">Portions</span>
                <div class="persons-control">
                    <button class="persons-btn" @onclick="DecreasePersons" disabled="@(currentPersons <= 1)">−</button>
                    <span class="persons-value">@currentPersons</span>
                    <button class="persons-btn" @onclick="IncreasePersons">+</button>
                </div>
                <span class="persons-hint">personnes</span>
            </div>

            <!-- Ingredients -->
            <section class="recipe-section">
                <h2 class="section-title">
                    <span class="section-number">01</span>
                    Ingrédients
                </h2>
                <div class="ingredients-grid">
                    @foreach (var ri in recipe.RecipeIngredients!)
                    {
                        var qty = Math.Round(ri.Quantity * currentPersons / (double)basePersons, 2);
                        <div class="ingredient-item">
                            <span class="ingredient-name">@ri.Ingredient?.Name</span>
                            <span class="ingredient-dots"></span>
                            <span class="ingredient-qty">@qty <em>@ri.Ingredient?.Unit?.Abbreviation</em></span>
                        </div>
                    }
                </div>
            </section>

            <!-- Preparation -->
            <section class="recipe-section">
                <h2 class="section-title">
                    <span class="section-number">02</span>
                    Préparation
                </h2>
                <div class="cooking-method">
                    @recipe.CookingMethod
                </div>
            </section>
        </div>

        <!-- Right Column — Nutrition Sidebar -->
        <aside class="recipe-sidebar">
            <div class="nutrition-card">
                <h3 class="nutrition-title">Valeurs nutritives</h3>
                <p class="nutrition-subtitle">pour @currentPersons personne@(currentPersons > 1 ? "s" : "")</p>

                <div class="nutrition-stat main-stat">
                    <span class="stat-value">@Math.Round(CalculateTotalCalories(recipe))</span>
                    <span class="stat-label">kcal total</span>
                </div>

                <div class="nutrition-divider"></div>

                <div class="nutrition-stat">
                    <span class="stat-value">@Math.Round(CaloriesPerPerson(recipe))</span>
                    <span class="stat-label">kcal / personne</span>
                </div>

                <div class="nutrition-divider"></div>

                <div class="macro-grid">
                    <div class="macro-item">
                        <div class="macro-bar" style="--pct: @GetMacroPct("proteins")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("proteins"), 1)g</span>
                        <span class="macro-label">Protéines</span>
                    </div>
                    <div class="macro-item">
                        <div class="macro-bar carbs" style="--pct: @GetMacroPct("carbs")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("carbs"), 1)g</span>
                        <span class="macro-label">Glucides</span>
                    </div>
                    <div class="macro-item">
                        <div class="macro-bar fats" style="--pct: @GetMacroPct("fats")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("fats"), 1)g</span>
                        <span class="macro-label">Lipides</span>
                    </div>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="info-card">
                <div class="info-row">
                    <span class="info-icon">🍽️</span>
                    <div>
                        <span class="info-label">Catégorie</span>
                        <span class="info-value">@recipe.Category?.Name</span>
                    </div>
                </div>
                <div class="info-row">
                    <span class="info-icon">🌍</span>
                    <div>
                        <span class="info-label">Cuisine</span>
                        <span class="info-value">@recipe.CuisineType?.Name</span>
                    </div>
                </div>
                <div class="info-row">
                    <span class="info-icon">🧂</span>
                    <div>
                        <span class="info-label">Ingrédients</span>
                        <span class="info-value">@recipe.RecipeIngredients?.Count éléments</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
}


@code {
    [Parameter] public int Id { get; set; }
    private int basePersons;
    private int currentPersons;
    private Recipe? recipe;

    protected override async Task OnInitializedAsync()
    {
        recipe = await RecipeService.GetRecipeByIdAsync(Id);
        if (recipe != null)
        {
            basePersons = recipe.NumberOfPersons;
            currentPersons = recipe.NumberOfPersons;
        }
    }

    private double CalculateTotalCalories(Recipe recipe)
    {
        if (recipe.RecipeIngredients == null) return 0;
        return recipe.RecipeIngredients.Sum(ri =>
            (ri.Ingredient?.CaloriesPerUnit ?? 0) * (ri.Quantity * currentPersons / (double)basePersons));
    }

    private double CaloriesPerPerson(Recipe recipe)
    {
        if (currentPersons == 0) return 0;
        return CalculateTotalCalories(recipe) / currentPersons;
    }

    private double GetMacroTotal(string macro)
    {
        if (recipe?.RecipeIngredients == null) return 0;
        double factor = currentPersons / (double)basePersons;
        return macro switch
        {
            "proteins" => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Proteins ?? 0) * ri.Quantity * factor),
            "carbs"    => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Carbs ?? 0) * ri.Quantity * factor),
            "fats"     => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Fats ?? 0) * ri.Quantity * factor),
            _ => 0
        };
    }

    private double GetMacroPct(string macro)
    {
        double p = GetMacroTotal("proteins");
        double c = GetMacroTotal("carbs");
        double f = GetMacroTotal("fats");
        double total = p + c + f;
        if (total == 0) return 0;
        return macro switch
        {
            "proteins" => Math.Round(p / total * 100),
            "carbs"    => Math.Round(c / total * 100),
            "fats"     => Math.Round(f / total * 100),
            _ => 0
        };
    }

    private void GoBack() => Nav.NavigateTo("/recipes");
    private void IncreasePersons() => currentPersons++;
    private void DecreasePersons() { if (currentPersons > 1) currentPersons--; }
}
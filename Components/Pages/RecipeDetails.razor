@page "/recipes/{Id:int}"
@using NutriDish.Models
@using NutriDish.Services
@inject IRecipeService RecipeService
@inject NavigationManager Nav
@rendermode InteractiveServer


@if (recipe == null)
{
    <div class="recipe-loading">
        <div class="loading-spinner"></div>
        <p>Préparation en cours...</p>
    </div>
}
else
{
    <!-- Hero Section -->
    <div class="recipe-hero" style="background-image: url('@(string.IsNullOrEmpty(recipe.ImageUrl) ? "" : recipe.ImageUrl)')">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <button class="back-btn" @onclick="GoBack">
                ← Retour aux recettes
            </button>
            <div class="hero-meta">
                <span class="meta-tag">@recipe.Category?.Name</span>
                <span class="meta-tag">@recipe.CuisineType?.Name</span>
            </div>
            <h1 class="recipe-title">@recipe.Name</h1>
        </div>
    </div>

    <!-- Main Content -->
    <div class="recipe-body">

        <!-- Left Column -->
        <div class="recipe-main">

            <!-- Persons Selector -->
            <div class="persons-card">
                <span class="persons-label">Portions</span>
                <div class="persons-control">
                    <button class="persons-btn" @onclick="DecreasePersons" disabled="@(currentPersons <= 1)">−</button>
                    <span class="persons-value">@currentPersons</span>
                    <button class="persons-btn" @onclick="IncreasePersons">+</button>
                </div>
                <span class="persons-hint">personnes</span>
            </div>

            <!-- Ingredients -->
            <section class="recipe-section">
                <h2 class="section-title">
                    <span class="section-number">01</span>
                    Ingrédients
                </h2>
                <div class="ingredients-grid">
                    @foreach (var ri in recipe.RecipeIngredients!)
                    {
                        var qty = Math.Round(ri.Quantity * currentPersons / (double)basePersons, 2);
                        <div class="ingredient-item">
                            <span class="ingredient-name">@ri.Ingredient?.Name</span>
                            <span class="ingredient-dots"></span>
                            <span class="ingredient-qty">@qty <em>@ri.Ingredient?.Unit?.Abbreviation</em></span>
                        </div>
                    }
                </div>
            </section>

            <!-- Preparation -->
            <section class="recipe-section">
                <h2 class="section-title">
                    <span class="section-number">02</span>
                    Préparation
                </h2>
                <div class="cooking-method">
                    @recipe.CookingMethod
                </div>
            </section>
        </div>

        <!-- Right Column — Nutrition Sidebar -->
        <aside class="recipe-sidebar">
            <div class="nutrition-card">
                <h3 class="nutrition-title">Valeurs nutritives</h3>
                <p class="nutrition-subtitle">pour @currentPersons personne@(currentPersons > 1 ? "s" : "")</p>

                <div class="nutrition-stat main-stat">
                    <span class="stat-value">@Math.Round(CalculateTotalCalories(recipe))</span>
                    <span class="stat-label">kcal total</span>
                </div>

                <div class="nutrition-divider"></div>

                <div class="nutrition-stat">
                    <span class="stat-value">@Math.Round(CaloriesPerPerson(recipe))</span>
                    <span class="stat-label">kcal / personne</span>
                </div>

                <div class="nutrition-divider"></div>

                <div class="macro-grid">
                    <div class="macro-item">
                        <div class="macro-bar" style="--pct: @GetMacroPct("proteins")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("proteins"), 1)g</span>
                        <span class="macro-label">Protéines</span>
                    </div>
                    <div class="macro-item">
                        <div class="macro-bar carbs" style="--pct: @GetMacroPct("carbs")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("carbs"), 1)g</span>
                        <span class="macro-label">Glucides</span>
                    </div>
                    <div class="macro-item">
                        <div class="macro-bar fats" style="--pct: @GetMacroPct("fats")%"></div>
                        <span class="macro-value">@Math.Round(GetMacroTotal("fats"), 1)g</span>
                        <span class="macro-label">Lipides</span>
                    </div>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="info-card">
                <div class="info-row">
                    <span class="info-icon">🍽️</span>
                    <div>
                        <span class="info-label">Catégorie</span>
                        <span class="info-value">@recipe.Category?.Name</span>
                    </div>
                </div>
                <div class="info-row">
                    <span class="info-icon">🌍</span>
                    <div>
                        <span class="info-label">Cuisine</span>
                        <span class="info-value">@recipe.CuisineType?.Name</span>
                    </div>
                </div>
                <div class="info-row">
                    <span class="info-icon">🧂</span>
                    <div>
                        <span class="info-label">Ingrédients</span>
                        <span class="info-value">@recipe.RecipeIngredients?.Count éléments</span>
                    </div>
                </div>
            </div>
        </aside>
    </div>
}

<style>
    :root {
        --cream: #faf7f2;
        --dark: #1a1a18;
        --charcoal: #2d2d2a;
        --olive: #6b7c5c;
        --gold: #c9a84c;
        --rust: #b85c38;
        --light-border: #e8e2d9;
        --font-display: 'Playfair Display', Georgia, serif;
        --font-body: 'DM Sans', sans-serif;
    }

    body, .recipe-page {
        background: var(--cream);
        font-family: var(--font-body);
        color: var(--dark);
    }

    /* Loading */
    .recipe-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 60vh;
        gap: 1rem;
        font-family: var(--font-body);
        color: var(--charcoal);
        opacity: 0.6;
    }

    .loading-spinner {
        width: 40px;
        height: 40px;
        border: 3px solid var(--light-border);
        border-top-color: var(--gold);
        border-radius: 50%;
        animation: spin 0.9s linear infinite;
    }

    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Hero */
    .recipe-hero {
        position: relative;
        height: 520px;
        background-size: cover;
        background-position: center;
        background-color: var(--charcoal);
        overflow: hidden;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(26,26,24,0.2) 0%,
            rgba(26,26,24,0.85) 100%
        );
    }

    .hero-content {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        padding: 2.5rem 3rem;
        animation: fadeUp 0.6s ease both;
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .back-btn {
        background: rgba(255,255,255,0.12);
        border: 1px solid rgba(255,255,255,0.25);
        color: #fff;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        font-size: 0.82rem;
        font-family: var(--font-body);
        cursor: pointer;
        letter-spacing: 0.03em;
        transition: background 0.2s;
        margin-bottom: 1rem;
        display: inline-block;
    }

    .back-btn:hover {
        background: rgba(255,255,255,0.22);
    }

    .hero-meta {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
    }

    .meta-tag {
        background: var(--gold);
        color: var(--dark);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        padding: 0.25rem 0.75rem;
        border-radius: 3px;
        font-family: var(--font-body);
    }

    .recipe-title {
        font-family: var(--font-display);
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 700;
        color: #fff;
        line-height: 1.1;
        margin: 0;
        text-shadow: 0 2px 20px rgba(0,0,0,0.3);
    }

    /* Body Layout */
    .recipe-body {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 2.5rem;
        max-width: 1200px;
        margin: 0 auto;
        padding: 3rem 2rem;
        align-items: start;
    }

    @@media (max-width: 900px) {
        .recipe-body { grid-template-columns: 1fr; }
        .recipe-hero { height: 340px; }
        .hero-content { padding: 1.5rem; }
    }

    /* Persons Card */
    .persons-card {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        background: #fff;
        border: 1px solid var(--light-border);
        border-radius: 12px;
        padding: 1rem 1.5rem;
        margin-bottom: 2.5rem;
        width: fit-content;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        animation: fadeUp 0.5s 0.1s ease both;
    }

    .persons-label {
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--olive);
    }

    .persons-control {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .persons-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 1.5px solid var(--light-border);
        background: var(--cream);
        font-size: 1.2rem;
        line-height: 1;
        cursor: pointer;
        color: var(--charcoal);
        transition: all 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .persons-btn:hover:not(:disabled) {
        border-color: var(--gold);
        background: var(--gold);
        color: #fff;
    }

    .persons-btn:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .persons-value {
        font-family: var(--font-display);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--dark);
        min-width: 2rem;
        text-align: center;
    }

    .persons-hint {
        font-size: 0.82rem;
        color: #999;
    }

    /* Sections */
    .recipe-section {
        margin-bottom: 3rem;
        animation: fadeUp 0.5s 0.2s ease both;
    }

    .section-title {
        display: flex;
        align-items: baseline;
        gap: 1rem;
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 2px solid var(--light-border);
    }

    .section-number {
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        color: var(--gold);
        text-transform: uppercase;
    }

    /* Ingredients */
    .ingredients-grid {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .ingredient-item {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 0.65rem 0;
        border-bottom: 1px dashed var(--light-border);
    }

    .ingredient-item:last-child { border-bottom: none; }

    .ingredient-name {
        font-size: 0.95rem;
        color: var(--charcoal);
        white-space: nowrap;
    }

    .ingredient-dots {
        flex: 1;
        border-bottom: 1px dotted #ccc;
        margin-bottom: 4px;
    }

    .ingredient-qty {
        font-size: 0.95rem;
        font-weight: 500;
        color: var(--dark);
        white-space: nowrap;
    }

    .ingredient-qty em {
        font-style: normal;
        font-size: 0.8rem;
        color: var(--olive);
        margin-left: 3px;
    }

    /* Cooking Method */
    .cooking-method {
        font-size: 1rem;
        line-height: 1.85;
        color: #444;
        white-space: pre-line;
        background: #fff;
        border-left: 3px solid var(--gold);
        padding: 1.5rem 1.75rem;
        border-radius: 0 8px 8px 0;
    }

    /* Sidebar */
    .recipe-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        position: sticky;
        top: 1.5rem;
        animation: fadeUp 0.5s 0.3s ease both;
    }

    /* Nutrition Card */
    .nutrition-card {
        background: var(--dark);
        border-radius: 16px;
        padding: 1.75rem;
        color: #fff;
    }

    .nutrition-title {
        font-family: var(--font-display);
        font-size: 1.15rem;
        font-weight: 700;
        color: #fff;
        margin: 0 0 0.25rem;
    }

    .nutrition-subtitle {
        font-size: 0.78rem;
        color: rgba(255,255,255,0.45);
        margin: 0 0 1.5rem;
        letter-spacing: 0.04em;
    }

    .nutrition-stat {
        display: flex;
        flex-direction: column;
        padding: 0.75rem 0;
    }

    .nutrition-stat.main-stat .stat-value {
        font-size: 2.8rem;
        line-height: 1;
    }

    .stat-value {
        font-family: var(--font-display);
        font-size: 1.8rem;
        font-weight: 700;
        color: var(--gold);
    }

    .stat-label {
        font-size: 0.75rem;
        color: rgba(255,255,255,0.5);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 0.2rem;
    }

    .nutrition-divider {
        border: none;
        border-top: 1px solid rgba(255,255,255,0.08);
        margin: 0.25rem 0;
    }

    /* Macro bars */
    .macro-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0.75rem;
        margin-top: 1.25rem;
    }

    .macro-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.4rem;
    }

    .macro-bar {
        width: 100%;
        height: 4px;
        border-radius: 2px;
        background: rgba(255,255,255,0.12);
        position: relative;
        overflow: hidden;
    }

    .macro-bar::after {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: calc(var(--pct) * 1%);
        background: var(--rust);
        border-radius: 2px;
        transition: width 0.4s ease;
    }

    .macro-bar.carbs::after { background: var(--gold); }
    .macro-bar.fats::after  { background: var(--olive); }

    .macro-value {
        font-size: 0.85rem;
        font-weight: 500;
        color: #fff;
    }

    .macro-label {
        font-size: 0.65rem;
        color: rgba(255,255,255,0.4);
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    /* Info Card */
    .info-card {
        background: #fff;
        border: 1px solid var(--light-border);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .info-row {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.75rem 0;
        border-bottom: 1px solid var(--light-border);
    }

    .info-row:last-child { border-bottom: none; }

    .info-icon {
        font-size: 1.25rem;
        width: 2rem;
        text-align: center;
    }

    .info-label {
        display: block;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #aaa;
        margin-bottom: 2px;
    }

    .info-value {
        display: block;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--dark);
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private int basePersons;
    private int currentPersons;
    private Recipe? recipe;

    protected override async Task OnInitializedAsync()
    {
        recipe = await RecipeService.GetRecipeByIdAsync(Id);
        if (recipe != null)
        {
            basePersons = recipe.NumberOfPersons;
            currentPersons = recipe.NumberOfPersons;
        }
    }

    private double CalculateTotalCalories(Recipe recipe)
    {
        if (recipe.RecipeIngredients == null) return 0;
        return recipe.RecipeIngredients.Sum(ri =>
            (ri.Ingredient?.CaloriesPerUnit ?? 0) * (ri.Quantity * currentPersons / (double)basePersons));
    }

    private double CaloriesPerPerson(Recipe recipe)
    {
        if (currentPersons == 0) return 0;
        return CalculateTotalCalories(recipe) / currentPersons;
    }

    private double GetMacroTotal(string macro)
    {
        if (recipe?.RecipeIngredients == null) return 0;
        double factor = currentPersons / (double)basePersons;
        return macro switch
        {
            "proteins" => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Proteins ?? 0) * ri.Quantity * factor),
            "carbs"    => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Carbs ?? 0) * ri.Quantity * factor),
            "fats"     => recipe.RecipeIngredients.Sum(ri => (ri.Ingredient?.Fats ?? 0) * ri.Quantity * factor),
            _ => 0
        };
    }

    private double GetMacroPct(string macro)
    {
        double p = GetMacroTotal("proteins");
        double c = GetMacroTotal("carbs");
        double f = GetMacroTotal("fats");
        double total = p + c + f;
        if (total == 0) return 0;
        return macro switch
        {
            "proteins" => Math.Round(p / total * 100),
            "carbs"    => Math.Round(c / total * 100),
            "fats"     => Math.Round(f / total * 100),
            _ => 0
        };
    }

    private void GoBack() => Nav.NavigateTo("/recipes");
    private void IncreasePersons() => currentPersons++;
    private void DecreasePersons() { if (currentPersons > 1) currentPersons--; }
}
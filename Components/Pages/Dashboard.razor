@page "/"
@using NutriDish.Models
@using NutriDish.Services
@using Radzen.Blazor
@using Radzen
@rendermode InteractiveServer
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject ICategoryService CategoryService
@inject ICuisineTypeService CuisineTypeService
@inject NavigationManager Nav


@if (!isLoaded)
{
    <div class="dash-loading">
        <div class="loading-spinner"></div>
        <p>Chargement du tableau de bord...</p>
    </div>
}
else
{
    <div class="dashboard">

        <!-- Header -->
        <div class="dash-header">
            <div>
                <h1 class="dash-title">Tableau de bord</h1>
                <p class="dash-subtitle">Vue d'ensemble de NutriDish</p>
            </div>
            <div class="dash-date">@DateTime.Now.ToString("dddd dd MMMM yyyy", new System.Globalization.CultureInfo("fr-FR"))</div>
        </div>

        <!-- KPI Cards -->
        <div class="kpi-grid">
            <div class="kpi-card" @onclick='() => Nav.NavigateTo("/recipes")'>
                <div class="kpi-icon" style="background: linear-gradient(135deg, #2e5f2e, #3d7a3d)">📖</div>
                <div class="kpi-info">
                    <span class="kpi-value">@totalRecipes</span>
                    <span class="kpi-label">Recettes</span>
                </div>
            </div>
            <div class="kpi-card" @onclick='() => Nav.NavigateTo("/ingredients")'>
                <div class="kpi-icon" style="background: linear-gradient(135deg, #c9a84c, #e0be6e)">🧂</div>
                <div class="kpi-info">
                    <span class="kpi-value">@totalIngredients</span>
                    <span class="kpi-label">Ingrédients</span>
                </div>
            </div>
            <div class="kpi-card" @onclick='() => Nav.NavigateTo("/categories")'>
                <div class="kpi-icon" style="background: linear-gradient(135deg, #1e3f1e, #2e5f2e)">🗂️</div>
                <div class="kpi-info">
                    <span class="kpi-value">@totalCategories</span>
                    <span class="kpi-label">Catégories</span>
                </div>
            </div>
            <div class="kpi-card" @onclick='() => Nav.NavigateTo("/cuisine-types")'>
                <div class="kpi-icon" style="background: linear-gradient(135deg, #b85c38, #d4714a)">🌍</div>
                <div class="kpi-info">
                    <span class="kpi-value">@totalCuisineTypes</span>
                    <span class="kpi-label">Types de cuisine</span>
                </div>
            </div>
        </div>

        <!-- Nutrition KPIs -->
        <div class="section-title-row">
            <h2 class="section-heading">🔥 Nutrition</h2>
        </div>

        <div class="nutrition-grid">
            <div class="nutrition-card dark">
                <span class="nutrition-label">Calories moyennes / recette</span>
                <span class="nutrition-value">@Math.Round(avgCaloriesPerRecipe)</span>
                <span class="nutrition-unit">kcal</span>
            </div>
            <div class="nutrition-card dark">
                <span class="nutrition-label">Calories moyennes / personne</span>
                <span class="nutrition-value">@Math.Round(avgCaloriesPerPerson)</span>
                <span class="nutrition-unit">kcal</span>
            </div>
            <div class="nutrition-card highlight" @onclick='() => Nav.NavigateTo($"/recipes/{mostCaloricRecipe?.Id}")'>
                <span class="nutrition-label">🏆 Recette la plus calorique</span>
                <span class="nutrition-recipe-name">@mostCaloricRecipe?.Name</span>
                <span class="nutrition-value gold">@Math.Round(mostCaloricCalories)</span>
                <span class="nutrition-unit">kcal</span>
            </div>
            <div class="nutrition-card highlight" @onclick='() => Nav.NavigateTo($"/recipes/{healthiestRecipe?.Id}")'>
                <span class="nutrition-label">🥗 Recette la plus healthy</span>
                <span class="nutrition-recipe-name">@healthiestRecipe?.Name</span>
                <span class="nutrition-value green">@Math.Round(healthiestCalories)</span>
                <span class="nutrition-unit">kcal</span>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="section-title-row">
            <h2 class="section-heading">📊 Analyses</h2>
        </div>

        <div class="charts-grid">
            <!-- Pie: recettes par catégorie -->
            <div class="chart-card">
                <h3 class="chart-title">Recettes par catégorie</h3>
                <RadzenPieChart Style="height:280px">
                    <RadzenPieSeries Data="@recipesByCategory"
                                     Title="Recettes"
                                     CategoryProperty="Label"
                                     ValueProperty="Value"
                                     Fills="@greenPalette">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenPieSeries>
                    <RadzenLegend Position="LegendPosition.Bottom" />
                </RadzenPieChart>
            </div>

            <!-- Bar: recettes par cuisine -->
            <div class="chart-card">
                <h3 class="chart-title">Recettes par type de cuisine</h3>
                <RadzenBarChart Style="height:280px">
                    <RadzenBarSeries Data="@recipesByCuisine"
                                     Title="Recettes"
                                     CategoryProperty="Label"
                                     ValueProperty="Value"
                                     Fill="#3d7a3d">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenBarSeries>
                    <RadzenCategoryAxis Padding="20" />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" Stroke="#cde0cd" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="false" />
                </RadzenBarChart>
            </div>

            <!-- Donut: répartition calorique -->
            <div class="chart-card">
                <h3 class="chart-title">Répartition calorique</h3>
                <RadzenDonutChart Style="height:280px">
                    <RadzenDonutSeries Data="@calorieDistribution"
                                       Title="Recettes"
                                       CategoryProperty="Label"
                                       ValueProperty="Value"
                                       Fills="@calorieColors">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenDonutSeries>
                    <RadzenLegend Position="LegendPosition.Bottom" />
                </RadzenDonutChart>
            </div>
        </div>

        <!-- Bottom Row: Top 5 tables -->
        <div class="tables-grid">

            <!-- Top 5 caloriques -->
            <div class="table-card">
                <h3 class="chart-title">🏆 Top 5 plus caloriques</h3>
                <div class="rank-list">
                    @foreach (var (recipe, index) in top5Caloric.Select((r, i) => (r, i)))
                    {
                        <div class="rank-item" @onclick='() => Nav.NavigateTo($"/recipes/{recipe.Recipe.Id}")'>
                            <span class="rank-number rank-@(index + 1)">@(index + 1)</span>
                            <span class="rank-name">@recipe.Recipe.Name</span>
                            <span class="rank-value red">@Math.Round(recipe.Calories) kcal</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Top 5 healthy -->
            <div class="table-card">
                <h3 class="chart-title">🥦 Top 5 plus healthy</h3>
                <div class="rank-list">
                    @foreach (var (recipe, index) in top5Healthy.Select((r, i) => (r, i)))
                    {
                        <div class="rank-item" @onclick='() => Nav.NavigateTo($"/recipes/{recipe.Recipe.Id}")'>
                            <span class="rank-number rank-@(index + 1)">@(index + 1)</span>
                            <span class="rank-name">@recipe.Recipe.Name</span>
                            <span class="rank-value green">@Math.Round(recipe.Calories) kcal</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Stats smart -->
            <div class="table-card">
                <h3 class="chart-title">📊 Statistiques avancées</h3>
                <div class="stats-list">
                    <div class="stat-row">
                        <span class="stat-row-label">Moy. ingrédients / recette</span>
                        <span class="stat-row-value">@Math.Round(avgIngredientsPerRecipe, 1)</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">Recettes low calorie ( moins de 300)</span>
                        <span class="stat-row-value green">@lowCalorie</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">Recettes medium (300–600)</span>
                        <span class="stat-row-value gold">@mediumCalorie</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">Recettes high calorie (> 600)</span>
                        <span class="stat-row-value red">@highCalorie</span>
                    </div>
                    <div class="stat-row">
                        <span class="stat-row-label">Total calories (toutes recettes)</span>
                        <span class="stat-row-value">@Math.Round(totalCaloriesAllRecipes) kcal</span>
                    </div>
                </div>
            </div>
        </div>

    </div>
}

<style>
    .dashboard {
        padding: 1.5rem 2rem;
        font-family: 'DM Sans', sans-serif;
        max-width: 1400px;
        margin: 0 auto;
    }

    .dash-loading {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 60vh;
        gap: 1rem;
        color: #6b8c6b;
    }

    .loading-spinner {
        width: 40px; height: 40px;
        border: 3px solid #cde0cd;
        border-top-color: #3d7a3d;
        border-radius: 50%;
        animation: spin 0.9s linear infinite;
    }
    @@keyframes spin { to { transform: rotate(360deg); } }

    /* Header */
    .dash-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2rem;
    }

    .dash-title {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        color: #1a2e1a;
        margin: 0;
    }

    .dash-subtitle {
        font-size: 0.85rem;
        color: #6b8c6b;
        margin: 0.2rem 0 0;
    }

    .dash-date {
        font-size: 0.8rem;
        color: #6b8c6b;
        text-transform: capitalize;
        background: #fff;
        border: 1px solid #cde0cd;
        padding: 0.4rem 0.9rem;
        border-radius: 20px;
    }

    /* KPI Grid */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 900px) { .kpi-grid { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 500px) { .kpi-grid { grid-template-columns: 1fr; } }

    .kpi-card {
        background: #fff;
        border: 1px solid #cde0cd;
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        cursor: pointer;
        box-shadow: 0 2px 12px rgba(30,63,30,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
    }

    .kpi-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(30,63,30,0.12);
    }

    .kpi-icon {
        width: 52px; height: 52px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        flex-shrink: 0;
    }

    .kpi-info { display: flex; flex-direction: column; }

    .kpi-value {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: #1a2e1a;
        line-height: 1;
    }

    .kpi-label {
        font-size: 0.78rem;
        color: #6b8c6b;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-top: 0.2rem;
    }

    /* Section headings */
    .section-title-row { margin: 1.5rem 0 1rem; }

    .section-heading {
        font-family: 'Playfair Display', serif;
        font-size: 1.3rem;
        color: #1a2e1a;
        margin: 0;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #cde0cd;
    }

    /* Nutrition Grid */
    .nutrition-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 900px) { .nutrition-grid { grid-template-columns: repeat(2, 1fr); } }

    .nutrition-card {
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        border: 1px solid #cde0cd;
        box-shadow: 0 2px 8px rgba(30,63,30,0.05);
    }

    .nutrition-card.dark {
        background: linear-gradient(135deg, #1e3f1e, #2e5f2e);
        border-color: #3d7a3d;
        color: #fff;
    }

    .nutrition-card.highlight {
        background: #fff;
        cursor: pointer;
        transition: transform 0.2s;
    }

    .nutrition-card.highlight:hover { transform: translateY(-3px); }

    .nutrition-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        opacity: 0.7;
    }

    .nutrition-card.dark .nutrition-label { color: rgba(255,255,255,0.6); }
    .nutrition-card.highlight .nutrition-label { color: #6b8c6b; }

    .nutrition-recipe-name {
        font-family: 'Playfair Display', serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: #1a2e1a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .nutrition-value {
        font-family: 'Playfair Display', serif;
        font-size: 2.2rem;
        font-weight: 700;
        line-height: 1;
    }

    .nutrition-card.dark .nutrition-value { color: #c9a84c; }
    .nutrition-value.gold { color: #c9a84c; }
    .nutrition-value.green { color: #3d7a3d; }

    .nutrition-unit {
        font-size: 0.75rem;
        opacity: 0.6;
    }

    /* Charts */
    .charts-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 1100px) { .charts-grid { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 700px)  { .charts-grid { grid-template-columns: 1fr; } }

    .chart-card {
        background: #fff;
        border: 1px solid #cde0cd;
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 2px 8px rgba(30,63,30,0.05);
    }

    .chart-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        color: #1a2e1a;
        margin: 0 0 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid #eef5ee;
    }

    /* Tables */
    .tables-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 2rem;
    }

    @@media (max-width: 1100px) { .tables-grid { grid-template-columns: 1fr 1fr; } }
    @@media (max-width: 700px)  { .tables-grid { grid-template-columns: 1fr; } }

    .table-card {
        background: #fff;
        border: 1px solid #cde0cd;
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 2px 8px rgba(30,63,30,0.05);
    }

    /* Rank list */
    .rank-list { display: flex; flex-direction: column; gap: 0.5rem; }

    .rank-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.5rem 0.75rem;
        border-radius: 8px;
        cursor: pointer;
        transition: background 0.15s;
    }

    .rank-item:hover { background: #eef5ee; }

    .rank-number {
        width: 26px; height: 26px;
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.75rem;
        font-weight: 700;
        flex-shrink: 0;
        background: #eef5ee;
        color: #2e5f2e;
    }

    .rank-1 { background: #c9a84c; color: #fff; }
    .rank-2 { background: #aaa; color: #fff; }
    .rank-3 { background: #b85c38; color: #fff; }

    .rank-name {
        flex: 1;
        font-size: 0.85rem;
        color: #1a2e1a;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .rank-value { font-size: 0.8rem; font-weight: 600; white-space: nowrap; }

    /* Stats list */
    .stats-list { display: flex; flex-direction: column; }

    .stat-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.6rem 0;
        border-bottom: 1px dashed #cde0cd;
        font-size: 0.85rem;
    }

    .stat-row:last-child { border-bottom: none; }
    .stat-row-label { color: #6b8c6b; }
    .stat-row-value { font-weight: 600; color: #1a2e1a; }

    /* Colors */
    .green { color: #3d7a3d !important; }
    .gold  { color: #c9a84c !important; }
    .red   { color: #b85c38 !important; }
</style>

@code {
    private bool isLoaded = false;

    private List<Recipe> recipes = new();
    private int totalRecipes, totalIngredients, totalCategories, totalCuisineTypes;
    private double avgCaloriesPerRecipe, avgCaloriesPerPerson, totalCaloriesAllRecipes;
    private double avgIngredientsPerRecipe;
    private int lowCalorie, mediumCalorie, highCalorie;

    private Recipe? mostCaloricRecipe;
    private double mostCaloricCalories;
    private Recipe? healthiestRecipe;
    private double healthiestCalories;

    private List<ChartData> recipesByCategory = new();
    private List<ChartData> recipesByCuisine = new();
    private List<ChartData> calorieDistribution = new();

    private List<(Recipe Recipe, double Calories)> top5Caloric = new();
    private List<(Recipe Recipe, double Calories)> top5Healthy = new();

    private string[] greenPalette = new[]
    {
        "#2e5f2e", "#3d7a3d", "#5a9e5a", "#a8d1a8", "#c9a84c",
        "#b85c38", "#1e3f1e", "#d4e8d4", "#6b7c5c", "#e0be6e"
    };

    private string[] calorieColors = new[] { "#3d7a3d", "#c9a84c", "#b85c38" };

    protected override async Task OnInitializedAsync()
    {
        recipes        = await RecipeService.GetAllRecipesAsync();
        totalRecipes   = recipes.Count;
        totalIngredients  = (await IngredientService.GetAllIngredientsAsync()).Count;
        totalCategories   = (await CategoryService.GetAllCategoriesAsync()).Count;
        totalCuisineTypes = (await CuisineTypeService.GetAllCuisineTypesAsync()).Count;

        // Calories per recipe
        var calorieMap = recipes.Select(r => new
        {
            Recipe   = r,
            Calories = GetCalories(r),
            PerPerson = r.NumberOfPersons > 0 ? GetCalories(r) / r.NumberOfPersons : 0
        }).ToList();

        totalCaloriesAllRecipes = calorieMap.Sum(x => x.Calories);
        avgCaloriesPerRecipe    = calorieMap.Any() ? calorieMap.Average(x => x.Calories) : 0;
        avgCaloriesPerPerson    = calorieMap.Any() ? calorieMap.Average(x => x.PerPerson) : 0;
        avgIngredientsPerRecipe = recipes.Any() ? recipes.Average(r => r.RecipeIngredients?.Count ?? 0) : 0;

        var sorted = calorieMap.OrderByDescending(x => x.Calories).ToList();
        mostCaloricRecipe   = sorted.FirstOrDefault()?.Recipe;
        mostCaloricCalories = sorted.FirstOrDefault()?.Calories ?? 0;
        healthiestRecipe    = sorted.LastOrDefault()?.Recipe;
        healthiestCalories  = sorted.LastOrDefault()?.Calories ?? 0;

        top5Caloric = sorted.Take(5).Select(x => (x.Recipe, x.Calories)).ToList();
        top5Healthy = sorted.TakeLast(5).Reverse().Select(x => (x.Recipe, x.Calories)).ToList();

        lowCalorie    = calorieMap.Count(x => x.Calories < 300);
        mediumCalorie = calorieMap.Count(x => x.Calories >= 300 && x.Calories <= 600);
        highCalorie   = calorieMap.Count(x => x.Calories > 600);

        // Charts
        recipesByCategory = recipes
            .GroupBy(r => r.Category?.Name ?? "—")
            .Select(g => new ChartData { Label = g.Key, Value = g.Count() })
            .OrderByDescending(x => x.Value).ToList();

        recipesByCuisine = recipes
            .GroupBy(r => r.CuisineType?.Name ?? "—")
            .Select(g => new ChartData { Label = g.Key, Value = g.Count() })
            .OrderByDescending(x => x.Value).ToList();

        calorieDistribution = new List<ChartData>
        {
            new() { Label = "Low (< 300 kcal)",     Value = lowCalorie },
            new() { Label = "Medium (300–600 kcal)", Value = mediumCalorie },
            new() { Label = "High (> 600 kcal)",     Value = highCalorie }
        };

        isLoaded = true;
    }

    private double GetCalories(Recipe recipe)
    {
        if (recipe.RecipeIngredients == null) return 0;
        return recipe.RecipeIngredients.Sum(ri =>
            (ri.Ingredient?.CaloriesPerUnit ?? 0) * ri.Quantity);
    }

    private class ChartData
    {
        public string Label { get; set; } = "";
        public double Value { get; set; }
    }
}
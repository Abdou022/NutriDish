@page "/"
@using NutriDish.Models
@using NutriDish.Services
@using NutriDish.Components.UI.Dashboard
@using Radzen.Blazor
@using Radzen
@rendermode InteractiveServer
@inject IRecipeService RecipeService
@inject IIngredientService IngredientService
@inject ICategoryService CategoryService
@inject ICuisineTypeService CuisineTypeService

@if (!isLoaded)
{
    <div class="dash-loading">
        <div class="loading-spinner"></div>
        <p>Chargement du tableau de bord...</p>
    </div>
}
else
{
    <div class="dashboard">

        <!-- Header -->
        <div class="dash-header">
            <div>
                <h1 class="dash-title">Tableau de bord</h1>
                <p class="dash-subtitle">Vue d'ensemble de NutriDish</p>
            </div>
            <div class="dash-date">
                @DateTime.Now.ToString("dddd dd MMMM yyyy",
                    new System.Globalization.CultureInfo("fr-FR"))
            </div>
        </div>

        <!-- KPI Cards -->
        <div class="kpi-grid">
            <KpiCard Icon="📖" Label="Recettes"
                     Value="@totalRecipes"
                     NavigateTo="/recipes"
                     Gradient="linear-gradient(135deg, #2e5f2e, #3d7a3d)" />
            <KpiCard Icon="🧂" Label="Ingrédients"
                     Value="@totalIngredients"
                     NavigateTo="/ingredients"
                     Gradient="linear-gradient(135deg, #c9a84c, #e0be6e)" />
            <KpiCard Icon="🗂️" Label="Catégories"
                     Value="@totalCategories"
                     NavigateTo="/categories"
                     Gradient="linear-gradient(135deg, #1e3f1e, #2e5f2e)" />
            <KpiCard Icon="🌍" Label="Types de cuisine"
                     Value="@totalCuisineTypes"
                     NavigateTo="/cuisine-types"
                     Gradient="linear-gradient(135deg, #b85c38, #d4714a)" />
        </div>

        <!-- Nutrition -->
        <div class="section-title-row">
            <h2 class="section-heading">🔥 Nutrition</h2>
        </div>

        <div class="nutrition-grid">
            <NutritionCard Label="Calories moyennes / recette"
                           Value="@avgCaloriesPerRecipe"
                           Dark="true" />
            <NutritionCard Label="Calories moyennes / personne"
                           Value="@avgCaloriesPerPerson"
                           Dark="true" />
            <NutritionCard Label="🏆 Recette la plus calorique"
                           RecipeName="@mostCaloricRecipe?.Name"
                           Value="@mostCaloricCalories"
                           ValueColor="gold"
                           Clickable="true"
                           NavigateTo="@($"/recipes/{mostCaloricRecipe?.Id}")" />
            <NutritionCard Label="🥗 Recette la plus healthy"
                           RecipeName="@healthiestRecipe?.Name"
                           Value="@healthiestCalories"
                           ValueColor="green"
                           Clickable="true"
                           NavigateTo="@($"/recipes/{healthiestRecipe?.Id}")" />
        </div>

        <!-- Charts -->
        <div class="section-title-row">
            <h2 class="section-heading">📊 Analyses</h2>
        </div>

        <div class="charts-grid">
            
            <ChartCard Title="Recettes par catégorie">
                
                <RadzenChart Style="height:280px">
                    <RadzenPieSeries Data="@recipesByCategory"
                                     Title="Recettes"
                                     CategoryProperty="Label"
                                     ValueProperty="Value" 
                                     Fills="@greenPalette">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenPieSeries>
                    <RadzenLegend Position="LegendPosition.Bottom" />
                </RadzenChart>
            </ChartCard>

            <ChartCard Title="Recettes par type de cuisine">
                <RadzenChart Style="height:280px">
                    <RadzenBarSeries Data="@recipesByCuisine"
                                     Title="Recettes"
                                     CategoryProperty="Label"
                                     ValueProperty="Value"
                                     Fill="#3d7a3d">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenBarSeries>
                    <RadzenCategoryAxis Padding="20" />
                    <RadzenValueAxis>
                        <RadzenGridLines Visible="true" Stroke="#cde0cd" />
                    </RadzenValueAxis>
                    <RadzenLegend Visible="false" />
                </RadzenChart>
            </ChartCard>

            <ChartCard Title="Répartition calorique">
                <RadzenChart Style="height:280px">
                    <RadzenDonutSeries Data="@calorieDistribution"
                                       Title="Recettes"
                                       CategoryProperty="Label"
                                       ValueProperty="Value"
                                       Fills="@calorieColors">
                        <TooltipTemplate Context="data">
                            <div>@data.Label : <strong>@data.Value recettes</strong></div>
                        </TooltipTemplate>
                    </RadzenDonutSeries>
                    <RadzenLegend Position="LegendPosition.Bottom" />
                </RadzenChart>
            </ChartCard>
        </div>

        <!-- Bottom Row -->
        <div class="tables-grid">
            <RankList Title="🏆 Top 5 plus caloriques"
                      Items="@top5Caloric"
                      ValueColor="red" />

            <RankList Title="🥦 Top 5 plus healthy"
                      Items="@top5Healthy"
                      ValueColor="green" />

            <StatsCard Title="📊 Statistiques avancées"
                       Stats="@GetStats()" />
        </div>

    </div>
}

@code {
    private bool isLoaded = false;
    private List<Recipe> recipes = new();
    private int totalRecipes, totalIngredients, totalCategories, totalCuisineTypes;
    private double avgCaloriesPerRecipe, avgCaloriesPerPerson, totalCaloriesAllRecipes;
    private double avgIngredientsPerRecipe;
    private int lowCalorie, mediumCalorie, highCalorie;
    private Recipe? mostCaloricRecipe;
    private double mostCaloricCalories;
    private Recipe? healthiestRecipe;
    private double healthiestCalories;
    private List<ChartData> recipesByCategory = new();
    private List<ChartData> recipesByCuisine = new();
    private List<ChartData> calorieDistribution = new();
    private List<(Recipe Recipe, double Calories)> top5Caloric = new();
    private List<(Recipe Recipe, double Calories)> top5Healthy = new();

    private string[] greenPalette = new[]
    {
        "#2e5f2e", "#3d7a3d", "#5a9e5a", "#a8d1a8", "#c9a84c",
        "#b85c38", "#1e3f1e", "#d4e8d4", "#6b7c5c", "#e0be6e"
    };
    private string[] calorieColors = new[] { "#3d7a3d", "#c9a84c", "#b85c38" };

    protected override async Task OnInitializedAsync()
    {
        recipes           = await RecipeService.GetAllRecipesAsync();
        totalRecipes      = recipes.Count;
        totalIngredients  = (await IngredientService.GetAllIngredientsAsync()).Count;
        totalCategories   = (await CategoryService.GetAllCategoriesAsync()).Count;
        totalCuisineTypes = (await CuisineTypeService.GetAllCuisineTypesAsync()).Count;

        var calorieMap = recipes.Select(r => new
        {
            Recipe    = r,
            Calories  = GetCalories(r),
            PerPerson = r.NumberOfPersons > 0 ? GetCalories(r) / r.NumberOfPersons : 0
        }).ToList();

        totalCaloriesAllRecipes = calorieMap.Sum(x => x.Calories);
        avgCaloriesPerRecipe    = calorieMap.Any() ? calorieMap.Average(x => x.Calories) : 0;
        avgCaloriesPerPerson    = calorieMap.Any() ? calorieMap.Average(x => x.PerPerson) : 0;
        avgIngredientsPerRecipe = recipes.Any() ? recipes.Average(r => r.RecipeIngredients?.Count ?? 0) : 0;

        var sorted = calorieMap.OrderByDescending(x => x.Calories).ToList();
        mostCaloricRecipe   = sorted.FirstOrDefault()?.Recipe;
        mostCaloricCalories = sorted.FirstOrDefault()?.Calories ?? 0;
        healthiestRecipe    = sorted.LastOrDefault()?.Recipe;
        healthiestCalories  = sorted.LastOrDefault()?.Calories ?? 0;

        top5Caloric = sorted.Take(5).Select(x => (x.Recipe, x.Calories)).ToList();
        top5Healthy = sorted.TakeLast(5).Reverse().Select(x => (x.Recipe, x.Calories)).ToList();

        lowCalorie    = calorieMap.Count(x => x.Calories < 300);
        mediumCalorie = calorieMap.Count(x => x.Calories >= 300 && x.Calories <= 600);
        highCalorie   = calorieMap.Count(x => x.Calories > 600);

        recipesByCategory = recipes
            .GroupBy(r => r.Category?.Name ?? "—")
            .Select(g => new ChartData { Label = g.Key, Value = g.Count() })
            .OrderByDescending(x => x.Value).ToList();

        recipesByCuisine = recipes
            .GroupBy(r => r.CuisineType?.Name ?? "—")
            .Select(g => new ChartData { Label = g.Key, Value = g.Count() })
            .OrderByDescending(x => x.Value).ToList();

        calorieDistribution = new List<ChartData>
        {
            new() { Label = "Low (< 300 kcal)",     Value = lowCalorie },
            new() { Label = "Medium (300–600 kcal)", Value = mediumCalorie },
            new() { Label = "High (> 600 kcal)",     Value = highCalorie }
        };

        isLoaded = true;
    }

    private List<StatsCard.StatItem> GetStats() => new()
    {
        new() { Label = "Moy. ingrédients / recette",    Value = $"{Math.Round(avgIngredientsPerRecipe, 1)}" },
        new() { Label = "Recettes low calorie (< 300)",  Value = $"{lowCalorie}",    Color = "green" },
        new() { Label = "Recettes medium (300–600)",      Value = $"{mediumCalorie}", Color = "gold" },
        new() { Label = "Recettes high calorie (> 600)",  Value = $"{highCalorie}",   Color = "red" },
        new() { Label = "Total calories toutes recettes", Value = $"{Math.Round(totalCaloriesAllRecipes)} kcal" }
    };

    private double GetCalories(Recipe recipe)
    {
        if (recipe.RecipeIngredients == null) return 0;
        return recipe.RecipeIngredients.Sum(ri =>
            (ri.Ingredient?.CaloriesPerUnit ?? 0) * ri.Quantity);
    }

    private class ChartData
    {
        public string Label { get; set; } = "";
        public double Value { get; set; }
    }
}
@using NutriDish.Models
@using NutriDish.Services
@using NutriDish.Components.UI
@inject ICategoryService CategoryService
@inject ICuisineTypeService CuisineTypeService
@inject IIngredientService IngredientService

<ModalDialog @ref="modal" Id="@Id" Title="@Title">
    <ChildContent>

        <!-- Step indicator -->
        <div class="d-flex mb-4 gap-2">
            <div class="step-pill @(currentStep == 1 ? "active" : currentStep > 1 ? "done" : "")">
                1 · Infos générales
            </div>
            <div class="step-pill @(currentStep == 2 ? "active" : currentStep > 2 ? "done" : "")">
                2 · Ingrédients
            </div>
            <div class="step-pill @(currentStep == 3 ? "active" : "")">
                3 · Image
            </div>
        </div>

        <!-- Step 1: General Info -->
        @if (currentStep == 1)
        {
            <div class="mb-3">
                <label class="form-label">Nom de la recette</label>
                <input type="text" class="form-control"
                       @bind="Recipe!.Name"
                       placeholder="Ex: Couscous royal" />
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Catégorie</label>
                    <select class="form-select" @bind="Recipe!.CategoryId">
                        <option value="0">-- Choisir --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Type de cuisine</label>
                    <select class="form-select" @bind="Recipe!.CuisineTypeId">
                        <option value="0">-- Choisir --</option>
                        @foreach (var ct in cuisineTypes)
                        {
                            <option value="@ct.Id">@ct.Name</option>
                        }
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Nombre de personnes</label>
                <input type="number" class="form-control"
                       @bind="Recipe!.NumberOfPersons"
                       min="1" max="20" />
            </div>

            <div class="mb-3">
                <label class="form-label">Méthode de préparation</label>
                <textarea class="form-control" rows="4"
                          @bind="Recipe!.CookingMethod"
                          placeholder="Décrivez les étapes de préparation..."></textarea>
            </div>
        }

        <!-- Step 2: Ingredients -->
        @if (currentStep == 2)
        {
            <div class="d-flex gap-2 mb-3">
                <select class="form-select" @bind="selectedIngredientId">
                    <option value="0">-- Choisir un ingrédient --</option>
                    @foreach (var ing in availableIngredients)
                    {
                        <option value="@ing.Id">@ing.Name (@ing.Unit?.Abbreviation)</option>
                    }
                </select>
                <input type="number" class="form-control" style="max-width:120px"
                       @bind="selectedQuantity"
                       min="0.1" step="0.1"
                       placeholder="Qté" />
                <button class="btn btn-success" @onclick="AddIngredientLine">+</button>
            </div>

            @if (recipeIngredients.Count == 0)
            {
                <p class="text-muted text-center py-3">Aucun ingrédient ajouté</p>
            }
            else
            {
                <table class="table table-sm table-bordered">
                    <thead class="table-light">
                        <tr>
                            <th>Ingrédient</th>
                            <th>Quantité</th>
                            <th>Unité</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var line in recipeIngredients)
                        {
                            var ing = allIngredients.FirstOrDefault(i => i.Id == line.IngredientId);
                            <tr>
                                <td>@ing?.Name</td>
                                <td>@line.Quantity</td>
                                <td>@ing?.Unit?.Abbreviation</td>
                                <td class="text-center">
                                    <button class="btn btn-danger btn-sm"
                                            @onclick="() => RemoveIngredientLine(line)">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        }

        <!-- Step 3: Image -->
        @if (currentStep == 3)
        {
            <div class="mb-3">
                <label class="form-label">Image de la recette</label>
                <InputFile class="form-control" OnChange="HandleImageUpload" accept="image/*" />
            </div>

            @if (!string.IsNullOrEmpty(imagePreview))
            {
                <div class="text-center mt-3">
                    <img src="@imagePreview"
                         alt="Aperçu"
                         style="max-height:200px; max-width:100%; border-radius:8px; object-fit:cover;" />
                </div>
            }
            else if (!string.IsNullOrEmpty(Recipe?.ImageUrl))
            {
                <div class="text-center mt-3">
                    <img src="@Recipe.ImageUrl"
                         alt="Image actuelle"
                         style="max-height:200px; max-width:100%; border-radius:8px; object-fit:cover;" />
                    <p class="text-muted mt-1" style="font-size:0.85rem">Image actuelle</p>
                </div>
            }
            else
            {
                <p class="text-muted text-center py-3">Aucune image sélectionnée</p>
            }
        }

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger py-2 mt-2">@ErrorMessage</div>
        }

    </ChildContent>
    <FooterContent>
        @if (currentStep > 1)
        {
            <button class="btn btn-outline-secondary me-auto" @onclick="PreviousStep">
                ← Précédent
            </button>
        }
        <button class="btn btn-secondary" @onclick="HandleClose">Annuler</button>
        @if (currentStep < 3)
        {
            <button class="btn btn-primary" @onclick="NextStep">Suivant →</button>
        }
        else
        {
            <button class="btn btn-success" @onclick="HandleSubmit">@SubmitText</button>
        }
    </FooterContent>
</ModalDialog>

<style>
    .step-pill {
        flex: 1;
        text-align: center;
        padding: 6px 10px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 500;
        background: #f0f0f0;
        color: #888;
    }
    .step-pill.active {
        background: #0d6efd;
        color: white;
    }
    .step-pill.done {
        background: #198754;
        color: white;
    }
</style>

@code {
    private ModalDialog? modal;

    [Parameter, EditorRequired] public string Id { get; set; } = "";
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public string SubmitText { get; set; } = "Enregistrer";
    [Parameter] public Recipe? Recipe { get; set; }
    [Parameter] public List<RecipeIngredient> RecipeIngredients { get; set; } = new();
    [Parameter] public string ErrorMessage { get; set; } = "";
    [Parameter] public EventCallback<(Recipe, List<RecipeIngredient>, IBrowserFile?)> OnSubmit { get; set; }

    private List<Category> categories = new();
    private List<CuisineType> cuisineTypes = new();
    private List<Ingredient> allIngredients = new();
    private List<Ingredient> availableIngredients = new();

    private List<RecipeIngredient> recipeIngredients = new();

    private int selectedIngredientId = 0;
    private double selectedQuantity = 1;

    private int currentStep = 1;
    private string imagePreview = "";
    private IBrowserFile? selectedImageFile;

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
        cuisineTypes = await CuisineTypeService.GetAllCuisineTypesAsync();
        allIngredients = await IngredientService.GetAllIngredientsAsync();
    }

    public async Task Open()
    {
        currentStep = 1;
        imagePreview = "";
        selectedImageFile = null;
        recipeIngredients = RecipeIngredients.Select(ri => new RecipeIngredient
        {
            IngredientId = ri.IngredientId,
            Quantity = ri.Quantity
        }).ToList();
        RefreshAvailableIngredients();
        await modal!.Open();
    }

    public async Task Close() => await modal!.Close();

    private async Task HandleClose()
    {
        currentStep = 1;
        await modal!.Close();
    }

    private void RefreshAvailableIngredients()
    {
        var usedIds = recipeIngredients.Select(r => r.IngredientId).ToHashSet();
        availableIngredients = allIngredients.Where(i => !usedIds.Contains(i.Id)).ToList();
    }

    private void AddIngredientLine()
    {
        if (selectedIngredientId == 0 || selectedQuantity <= 0) return;

        recipeIngredients.Add(new RecipeIngredient
        {
            IngredientId = selectedIngredientId,
            Quantity = selectedQuantity
        });

        selectedIngredientId = 0;
        selectedQuantity = 1;
        RefreshAvailableIngredients();
    }

    private void RemoveIngredientLine(RecipeIngredient line)
    {
        recipeIngredients.Remove(line);
        RefreshAvailableIngredients();
    }

    private void NextStep()
    {
        if (currentStep < 3) currentStep++;
    }

    private void PreviousStep()
    {
        if (currentStep > 1) currentStep--;
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        selectedImageFile = e.File;
        var buffer = new byte[e.File.Size];
        await e.File.OpenReadStream(10 * 1024 * 1024).ReadAsync(buffer);
        var base64 = Convert.ToBase64String(buffer);
        imagePreview = $"data:{e.File.ContentType};base64,{base64}";
    }

    private async Task HandleSubmit()
    {
        await OnSubmit.InvokeAsync((Recipe!, recipeIngredients, selectedImageFile));
    }
}
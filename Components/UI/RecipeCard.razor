@using NutriDish.Models

<div class="card h-100 shadow-sm">
    @if (!string.IsNullOrEmpty(Recipe.ImageUrl))
    {
        <img src="@Recipe.ImageUrl" class="card-img-top"
             style="height:180px; object-fit:cover;" />
    }
    else
    {
        <div class="d-flex align-items-center justify-content-center"
             style="height:180px; background:#f5f5f5;">
            <span style="font-size:2rem;">🍽️</span>
        </div>
    }

    <div class="card-body">
        <h3 class="card-title">@Recipe.Name</h3>

        <p class="card-text text-muted mb-1">
            <strong>Catégorie:</strong> @Recipe.Category?.Name
        </p>

        <p class="card-text text-muted mb-1">
            <strong>Cuisine:</strong> @Recipe.CuisineType?.Name
        </p>

        <p class="card-text text-muted mb-2">
            👥 @Recipe.NumberOfPersons personnes
        </p>

        <span class="badge bg-success">
        🔥 @CalculateTotalCalories(Recipe) kcal
        </span>
    </div>

    <div class="card-footer d-flex justify-content-between">
        <button class="btn btn-warning btn-sm"
                @onclick="() => OnEdit.InvokeAsync(Recipe)">
            ✏️
        </button>

        <button class="btn btn-danger btn-sm"
                @onclick="() => OnDelete.InvokeAsync(Recipe)">
            🗑️
        </button>
    </div>
</div>

<style>
    .card {
    transition: transform 0.3s ease;
}
.card:hover {
    transform: scale(1.03);
}
</style>

@code {
    [Parameter] public Recipe Recipe { get; set; } = default!;

    [Parameter] public EventCallback<Recipe> OnEdit { get; set; }
    [Parameter] public EventCallback<Recipe> OnDelete { get; set; }

    private double CalculateTotalCalories(Recipe recipe)
    {
        if (recipe.RecipeIngredients == null)
            return 0;

        return recipe.RecipeIngredients.Sum(ri =>
            (ri.Ingredient?.CaloriesPerUnit ?? 0) * ri.Quantity
        );
    }        
}

